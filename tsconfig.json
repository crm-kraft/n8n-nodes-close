{
	"compilerOptions": {
		"target": "ES2019",
		"module": "commonjs",
		"lib": ["ES2019"],
		"strict": false,
		"declaration": true,
		"sourceMap": true,
		"declarationMap": true,
		"outDir": "./dist",
		"rootDir": ".",
		"typeRoots": ["./node_modules/@types"],
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"skipDefaultLibCheck": true
	},
	"include": ["credentials/**/*", "nodes/**/*"],
	"exclude": ["node_modules", "dist"]
}
